# Supabase (server + client). Copy to .env and fill in your project values.
SUPABASE_PROJECT_ID=""
SUPABASE_PUBLISHABLE_KEY=""
SUPABASE_URL=""
VITE_SUPABASE_PROJECT_ID=""
VITE_SUPABASE_PUBLISHABLE_KEY=""
VITE_SUPABASE_URL=""

# Analysis engine (optional). The "Pleading-to-Proof" analysis engine that turns a
# pleading + bundle into an AppData object. When set, the app POSTs to
# `${ENGINE_URL}/analyze`:
#   - cases/new          → analyzeBundle(files)   (fresh analysis, seeds a new case)
#   - Re-analyze button   → reanalyzeCase(...)    (re-runs after a pleaded edit)
# and expects an AppData JSON back (keys: meta, stats, nodes, edges, clusters).
# Leave UNSET to run the bundled demo: uploads load the sample case and the
# Re-analyze button shows a "connect the backend" note. Server-side only.
# ENGINE_URL="http://localhost:8000"
